---
import WaitlistForm from './WaitlistForm.astro';

interface Props {
  appName: string;
}

const { appName } = Astro.props;
---

<section class="relative min-h-screen flex items-center pt-20 sm:pt-24 pb-16 sm:pb-24 px-4 overflow-hidden bg-background">
  <!-- Dot grid pattern — subtle productivity tool vibe -->
  <div
    class="absolute inset-0 opacity-[0.035] pointer-events-none"
    style="background-image: radial-gradient(circle, #1A1A1A 1px, transparent 1px); background-size: 24px 24px;"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Headline + Copy -->
      <div class="text-center lg:text-left order-2 lg:order-1">
        <!-- Memorable element: italic serif headline -->
        <h1 class="font-heading text-display font-bold mb-6 leading-[1.05]" data-reveal>
          <em class="not-italic font-semibold text-primary">Tailor</em><span class="text-accent not-italic font-semibold">Apply</span>
          <br class="hidden sm:block" />
          <span class="text-text-main">Your Resume in Minutes,</span>
          <br class="hidden sm:block" />
          <span class="text-text-main">Not Hours</span>
        </h1>

        <p class="text-lead text-text-muted mb-8 max-w-xl mx-auto lg:mx-0" data-reveal data-reveal-delay="1">
          Stop spending 30–90 minutes tailoring each resume. TailorApply matches your existing experience to any job posting's keywords — so you can apply to twice as many jobs without the exhaustion.
        </p>

        <div data-reveal data-reveal-delay="2">
          <WaitlistForm
            projectName={appName}
            buttonText="Join the Waitlist — It's Free"
            formId="hero"
          />
        </div>

        <p class="text-sm text-text-muted mt-5" data-reveal data-reveal-delay="3">
          2,847 job seekers already on the waitlist
        </p>
      </div>

      <!-- Right: Browser mockup -->
      <div class="order-1 lg:order-2" data-reveal data-reveal-delay="1">
        <div class="relative mx-auto max-w-lg">
          <!-- Browser chrome -->
          <div class="bg-white rounded-2xl shadow-[0_8px_40px_rgba(0,0,0,0.12)] overflow-hidden border border-gray-200/60">
            <!-- Browser header -->
            <div class="bg-gray-100 px-4 py-3 flex items-center gap-2 border-b border-gray-200/60">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                <div class="w-3 h-3 rounded-full bg-green-400"></div>
              </div>
              <div class="flex-1 mx-4">
                <div class="bg-white rounded-md px-3 py-1 text-xs text-text-muted text-center">
                  app.tailorapply.com
                </div>
              </div>
            </div>

            <!-- App content mockup -->
            <div class="p-6 bg-surface">
              <!-- Job description input -->
              <div class="mb-5">
                <div class="text-xs font-semibold text-accent mb-2 uppercase tracking-wide">Job Description</div>
                <div class="bg-white rounded-xl p-4 border border-gray-200/80 text-sm text-text-muted leading-relaxed">
                  <p class="mb-2">We are looking for a <strong>Client Relationship Manager</strong> to join our growing team...</p>
                  <p class="text-xs text-text-muted/70">Requirements: Project Management, Account Handling, CRM...</p>
                </div>
              </div>

              <!-- Keyword matches -->
              <div>
                <div class="text-xs font-semibold text-accent mb-2 uppercase tracking-wide">Your Keywords Matched</div>
                <div class="space-y-2">
                  <div class="flex items-center gap-3 bg-white rounded-lg px-3 py-2.5 border border-gray-200/80">
                    <div class="w-5 h-5 rounded-full bg-success/15 flex items-center justify-center flex-shrink-0">
                      <svg class="w-3 h-3 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </div>
                    <span class="text-sm text-text-main">Client Relationship Management</span>
                    <span class="ml-auto text-xs text-success font-medium">Matched</span>
                  </div>
                  <div class="flex items-center gap-3 bg-white rounded-lg px-3 py-2.5 border border-gray-200/80">
                    <div class="w-5 h-5 rounded-full bg-primary/15 flex items-center justify-center flex-shrink-0">
                      <svg class="w-3 h-3 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                      </svg>
                    </div>
                    <span class="text-sm text-text-main">Project Management</span>
                    <span class="ml-auto text-xs text-primary font-medium">Add to resume</span>
                  </div>
                  <div class="flex items-center gap-3 bg-white rounded-lg px-3 py-2.5 border border-gray-200/80">
                    <div class="w-5 h-5 rounded-full bg-primary/15 flex items-center justify-center flex-shrink-0">
                      <svg class="w-3 h-3 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                      </svg>
                    </div>
                    <span class="text-sm text-text-main">Account Handling</span>
                    <span class="ml-auto text-xs text-primary font-medium">Add to resume</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating badge -->
          <div class="absolute -bottom-4 -right-4 sm:-right-8 bg-white rounded-xl shadow-card px-4 py-2.5 border border-gray-200/60 flex items-center gap-2">
            <div class="w-6 h-6 rounded-full bg-success/15 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <span class="text-xs font-semibold text-text-main">Tailored in <strong class="text-success">4:32</strong></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
