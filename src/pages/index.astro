---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ValueProposition from '../components/ValueProposition.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import Footer from '../components/Footer.astro';

const appName = 'tailorapply';
---

<Layout
  title="TailorApply — Tailor Your Resume in Minutes, Not Hours"
  description="Stop spending 30–90 minutes tailoring each resume. TailorApply matches your existing experience to any job posting's keywords — so you can apply to twice as many jobs."
>
  <Header appName={appName} />
  <main>
    <Hero appName={appName} />
    <ValueProposition appName={appName} />

    <!-- How It Works -->
    <section id="how-it-works" class="py-16 sm:py-24 px-4 bg-background">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12 sm:mb-16" data-reveal>
          <h2 class="font-heading text-title font-bold text-text-main mb-4">
            Three steps to a tailored resume
          </h2>
          <p class="text-lead text-text-muted max-w-xl mx-auto">
            No AI generating lies. No starting from scratch. Just your real experience, matched to their exact words.
          </p>
        </div>

        <div class="space-y-6 sm:space-y-8">
          <div class="flex gap-5 items-start" data-reveal data-reveal-delay="1">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold text-lg shadow-sm">1</div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-text-main mb-2">Paste your resume</h3>
              <p class="text-text-muted">Drop in your current resume as-is. No formatting required — we work with what you've already got.</p>
            </div>
          </div>

          <div class="flex gap-5 items-start" data-reveal data-reveal-delay="2">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold text-lg shadow-sm">2</div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-text-main mb-2">Paste the job description</h3>
              <p class="text-text-muted">Copy the job posting text. We'll instantly identify the keywords and skills they're actually screening for.</p>
            </div>
          </div>

          <div class="flex gap-5 items-start" data-reveal data-reveal-delay="3">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold text-lg shadow-sm">3</div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-text-main mb-2">Get your tailored resume</h3>
              <p class="text-text-muted">We show you exactly which keywords you're missing and where to add them. You approve every change. Takes 5 minutes.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof -->
    <section class="py-12 sm:py-16 px-4 bg-surface border-y border-gray-200/50">
      <div class="max-w-4xl mx-auto text-center" data-reveal>
        <p class="text-sm text-text-muted uppercase tracking-widest font-medium mb-4">Early waitlist</p>
        <p class="text-display font-heading font-bold text-text-main mb-2">2,847</p>
        <p class="text-lead text-text-muted">job seekers already signed up</p>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="py-16 sm:py-24 px-4 bg-background">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-title font-bold text-text-main text-center mb-12" data-reveal>
          Frequently Asked Questions
        </h2>

        <div class="space-y-4" data-reveal data-reveal-delay="1">
          {[
            {
              q: "How is this different from AI resume builders like Kickresume or Rezi?",
              a: "Those tools generate new content using AI — which often adds false information or obvious padding. We don't generate anything. We take your actual, real experience and show you exactly which keywords from the job posting you're missing and how to naturally incorporate them. The words stay yours."
            },
            {
              q: "Do I need to pay to use TailorApply?",
              a: "We're launching with a free tier that lets you tailor up to 5 resumes per month. A Pro plan with unlimited tailoring will be available at launch."
            },
            {
              q: "Will this actually help me pass ATS screening?",
              a: "Yes — because we're not guessing. We extract the exact keywords from the job description and show you precisely where to add them to your existing resume. If the posting asks for 'Client Relationship Management' and you have 'Account Handling,' we'll show you that match and how to bridge the gap."
            },
            {
              q: "What file formats do you support?",
              a: "Currently we support PDF and Word (.docx) uploads. Export is available in both formats."
            },
            {
              q: "When is TailorApply launching?",
              a: "We're targeting Q2 2026. Join the waitlist and you'll be among the first to get access — plus early adopters will receive a永久 free Pro plan."
            }
          ].map((item) => (
            <details class="group bg-surface rounded-2xl border border-gray-200/60 overflow-hidden">
              <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none text-left">
                <span class="font-heading font-semibold text-text-main">{item.q}</span>
                <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <div class="px-5 pb-5 text-text-muted leading-relaxed border-t border-gray-200/40 pt-4">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section id="join" class="py-16 sm:py-24 px-4 bg-surface">
      <div class="max-w-2xl mx-auto text-center" data-reveal>
        <h2 class="font-heading text-title font-bold text-text-main mb-4">
          Ready to apply to more jobs without the grind?
        </h2>
        <p class="text-lead text-text-muted mb-8">
          Join 2,847 job seekers on the waitlist. Early access is free.
        </p>
        <WaitlistForm
          projectName={appName}
          buttonText="Join the Waitlist"
          formId="final"
          variant="cta"
        />
      </div>
    </section>
  </main>
  <Footer appName={appName} />
</Layout>
